# Supabase — copy this file to ".env" and fill in your project values.
# Find them in Supabase: Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Maps Platform — enables exact address autocomplete on the
# "Leaving from" / "Going to" fields. Create a key in Google Cloud Console
# with the "Places API (New)" enabled, then restrict it to your site's domain.
# Leave blank to fall back to plain text entry (no suggestions).
VITE_GOOGLE_MAPS_API_KEY=
